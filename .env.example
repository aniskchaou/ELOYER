# Application ports
PORT=8080
API_PORT=3000

# PostgreSQL connection options
# Option A: single URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/eloyer

# Option B: discrete values
PGHOST=localhost
PGPORT=5432
PGDATABASE=eloyer
PGUSER=postgres
PGPASSWORD=postgres

# Set true when your provider requires SSL (for managed postgres)
PG_SSL=false

# Frontend API base (used by lawyer portal pages)
VUE_APP_API_BASE_URL=/api
